# Copy to .env and fill in. Only the providers you benchmark are required.

# E2B (https://e2b.dev) — required for `--provider e2b`
E2B_API_KEY=

# Hugging Face token (https://huggingface.co/settings/tokens) — required for `--provider hf`
HF_TOKEN=

# MCP remote-code-execution server (Streamable HTTP endpoint) — required for `--provider mcp`
MCP_ENDPOINT=
